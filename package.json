{
  "name": "turbo-shell",
  "version": "1.0.0",
  "description": "This a public library for manage the package installing on monorepos.",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "start": "node dist/index.cjs",
    "dev": "cross-env NODE_ENV=viper-test tsx src/index.ts",
    "dev:build": "cross-env NODE_ENV=viper-test node dist/index.cjs",
    "test": "cross-env NODE_ENV=viper-test vitest",
    "build": "tsup src --env.NODE_ENV prod",
    "ci:publish": "npm build && changeset publish --access public",
    "release": "changeset",
    "prepare": "husky",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prettier:write": "npx prettier . --write",
    "prettier:check": "npx prettier . --check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RadamantiumX/monorepo-pkg-manager.git"
  },
  "keywords": [
    "turbo-repo",
    "npm",
    "pnpm",
    "yarn",
    "management",
    "monorepo",
    "console",
    "facebook",
    "instagram",
    "github",
    "prisma",
    "vercel"
  ],
  "author": "RadamantiumX",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/RadamantiumX/monorepo-pkg-manager/issues"
  },
  "homepage": "https://github.com/RadamantiumX/monorepo-pkg-manager#readme",
  "dependencies": {
    "@inquirer/prompts": "7.10.1",
    "ansi-colors": "4.1.3",
    "dotenv": "^17.4.2",
    "import-local": "^3.2.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.8.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "3.8.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write --ignore-unknown"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json",
    "./bin/turbo-shell": "./bin/turbo-shell.js"
  },
  "bin": {
    "turbo-shell": "./bin/turbo-shell.js"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "imports": {
    "#main-prod/*": "./dist/*.cjs",
    "#main-dev/*": "./src/*.ts"
  }
}
